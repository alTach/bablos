include ../mixin/wrapper
include ../mixin/block-subtitle

-var arr = [[],[]];
-arr[0].push({totalNumber: "Б 5 500 000"});
-arr[0].push({name: "Производство фильма", value: "66,4%"});
-arr[0].push({name: "Рекламная кампания и маркетинг", value: "16,6%"});
-arr[0].push({name: "Резервный фонд", value: "9%"});
-arr[0].push({name: "Эдвайзеры, звёзды, команда.", value: "8%"});
-arr[1].push({totalNumber: "Б 7 000 000"});
-arr[1].push({name: "Производство фильма", value: "57%"});
-arr[1].push({name: "Рекламная кампания и маркетинг", value: "14%"});
-arr[1].push({name: "Резервный фонд", value: "9%"});
-arr[1].push({name: "Эдвайзеры, звёзды, команда", value: "8%"});
-arr[1].push({name: "Компьютерная графика", value: "6%"});
-arr[1].push({name: "Развитие платформы", value: "6%"});



+wrapper("bb-token-distribution")
    -var text = "Распределение токенов"
    +block-subtitle(text)
    each row in arr
        div(class="uk-grid-large uk-child-width-1-2@s uk-flex-center uk-text-center bb-token-distribution-card-list" uk-grid)
            div.bb-token-distribution-card
                each card in row
                    if card.totalNumber
                        p.bb-token-distribution-volume(uk-parallax="opacity: 0,1; y: 50,0; viewport: 0.4")= card.totalNumber
                    ul.uk-list.bb-token-distribution-text
                            li.bb-token-distribution-value 
                                span(uk-parallax="opacity: 0,1; y: 50,0; viewport: 0.3")= card.value
                            li.bb-token-distribution-description 
                                span(uk-parallax="opacity: 0,1; y: 50,0; viewport: 0.3")= card.name
            div.bb-token-distribution-card
                div(class="uk-card uk-card-body")
