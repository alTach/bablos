include ../mixin/wrapper
include ../mixin/block-name

+wrapper("bb-stand-film-produsser")
    +block-name("СТАНЬ ПРОДЮСЕРОМ ФИЛЬМА")
    div(class="uk-grid-large uk-child-width-1-3@s uk-flex-center uk-text-center bb-stand-film-produsser-card-list" uk-grid)
            each card in [{name: "Генеральный продюсер", value: "Б 1 000 000"}, {name: "Со-продюсер", value: "Б 200 000"}, {name: "ICO-продюсер", value: "Б 10 000"}]
                div
                    div(class="uk-card uk-card-body")
                        p.stand-film-produsser-name(uk-parallax=" opacity: 0,1; viewport: 0.2")= card.name
                        img(src="../../img/shape.png", alt="" class="bb-stand-film-produsser-img-back", uk-parallax=" rotate: 360; scale: 2; viewport: 0.2")
                        img(src="../../img/bablo-coin-obverse.png", alt="" class="bb-stand-film-produsser-img-front", uk-parallax="opacity: 0,1; viewport: 0.4")
                        p.block-chain-category-name(uk-parallax=" opacity: 0,1; viewport: 0.2")= card.value
                        button(class="uk-button bb-btn uk-padding-small uk-padding-remove-top uk-padding-remove-bottom", uk-parallax=" opacity: 0,1; viewport: 0.2") Оставить заявку      
                    
                

