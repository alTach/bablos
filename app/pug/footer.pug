section.footer-top
    .container
        .footer-top.card-list.uk-clearfix
            div(class="footer-top-card subscribe")
                p.subscribe-name.subscribe-name_left Подписаться на новости
                form
                    div(class="uk-margin subscribe-input-wrapper")
                                div(class="uk-inline subscribe-input-block")
                                    a(class="uk-form-icon uk-form-icon-flip" href="#") Подписаться
                                    input(class="uk-input subscribe-input" type="text" placeholder="Введите email")
            div(class="footer-top-card in-social")
                p.subscribe-name Мы в социальных сетях
                div
                    each social in ["facebook","twitter","instagram","youtube","heart","linkedin","github"]
                        span(uk-icon=social class="in-social-icon")
            div(class="footer-top-card to-discussion")
                p.subscribe-name Общайтесь
                div
                    each item in [{name: "Русский", region: "ru"}, {name: "Английский", region: "en"}]
                        span(uk-icon="" class="in-social-icon" id="footre-region-ru")
                            svg(xmlns="http://www.w3.org/2000/svg" height="20" viewBox="0 0 1792 1792" width="20")
                                path(d="M1764 11q33 24 27 64l-256 1536q-5 29-32 45-14 8-31 8-11 0-24-5l-453-185-242 295q-18 23-49 23-13 0-22-4-19-7-30.5-23.5t-11.5-36.5v-349l864-1059-1069 925-395-162q-37-14-40-55-2-40 32-59l1664-960q15-9 32-9 20 0 36 11z")
                        label(for="footer-region-" + item.region)= item.name
section.footer-bottom
    .container
        nav.uk-navbar-container(uk-navbar)
            .uk-navbar-left
                ul.uk-navbar-nav
                    li
                        a(href="#") 2018 © Баблос Интертеймент
            .uk-navbar-right
                ul.uk-navbar-nav
                    each item in ["О фильме", "Условия", "Дорожная карта", "White Paper", "Команда"]
                        li
                            a(href="#")= item
                    